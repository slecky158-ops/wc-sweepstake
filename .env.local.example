# Copy to .env.local for local dev. In Vercel, paste these into Project Settings → Environment Variables.

# From Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# From scraperapi.com dashboard
SCRAPERAPI_KEY=your-scraperapi-key

# Any random string. Used to authenticate Vercel Cron requests.
CRON_SECRET=change-me-to-a-random-string
